            static_attrs_map = edge_static_attrs.setdefault(graph_type, {})
            for edge_type, edge_index in list(edge_map.items()):
                src_type, relation, dst_type = edge_type
                reverse_type = (dst_type, f"rev_{relation}", src_type)
