                "causal": {
                    "features": ["causal_score", "attn_alpha_train_mean", "attn_alpha_train_last", "attn_alpha_full_last", "lag", "tau"],
                    "builder": lambda row, dyn_row: [
                        float(row.get("causal_score", 0.0)),
