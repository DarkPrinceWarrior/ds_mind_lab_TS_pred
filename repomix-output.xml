    graph_edge_static = _build_graph_edge_static(summary_df)
    graph_edge_temporal = _build_graph_edge_temporal(
        summary_df,
        alpha_timeseries,
        full_index,
        train_mask,
        inj_rate,
        inj_wwit_diff,
        pair_details,
        use_crm=use_crm,
    )
